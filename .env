# =============================================================================
# TCCK MAP — .env
# ВАЖНО: добавь .env в .gitignore — этот файл НЕ должен быть в git
# =============================================================================

# --- ШАГ 1: Получить на https://my.telegram.org → "API development tools" ---
TELEGRAM_API_ID=25118513            # числовой ID, например: 12345678
TELEGRAM_API_HASH=b418c3fed41f4205597ef1124ab43169          # строка вида: a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4
# Номер телефона аккаунта — нужен только при первом запуске gen_session.py
TELEGRAM_PHONE=+380662528640             # например: +380501234567
# StringSession — оставь пустым сейчас.
# После запуска tools/gen_session.py — вставь сюда длинную строку.
TELEGRAM_STRING_SESSION=

# --- ШАГ 2: Канал для мониторинга ---
# @username публичного/приватного канала ИЛИ числовой ID
# Числовой ID узнать: перешли любое сообщение из канала боту @userinfobot
TARGET_CHANNEL=-1002050105527             # например: @my_channel  или  -1001234567890
# --- ШАГ 3: Получить на https://console.anthropic.com → API Keys ---
OPENROUTER_API_KEY=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          # вид: sk-ant-api03-XXXX...
# --- Настройки приложения (менять не обязательно) ---
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Время жизни маркера на карте (секунды). 7200 = 2 часа
LOCATION_TTL_SECONDS=7200

# Как часто чистить устаревшие записи (секунды)
CLEANUP_INTERVAL_SECONDS=300

# OSM Nominatim: укажи свой email — требование ToS OpenStreetMap
NOMINATIM_USER_AGENT=tcck-map/1.0 vbagrat.od@gmail.com

# Путь к SQLite базе (относительно папки backend/)
# На Render: /data/tcck_map.db
DB_PATH=tcck_map.db

# Переподключение Telethon
RECONNECT_BASE_DELAY=5.0
RECONNECT_MAX_DELAY=300.0
RECONNECT_MAX_ATTEMPTS=0
